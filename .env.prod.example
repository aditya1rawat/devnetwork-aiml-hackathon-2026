# Production env file consumed by docker-compose.prod.yml. Copy to
# .env.prod on the Droplet and fill in the secrets. NEVER commit .env.prod.

# --- AI providers ---
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_GATEWAY_URL=https://gateway.truefoundry.ai
CLAUDE_MODEL=anthropic/claude-sonnet-4-6
TRIAGE_MODEL=anthropic/claude-haiku-4-5
NEMOTRON_MODEL=nvidia/Nemotron-3-Nano-Omni-Reasoning-30B-A3B

ANTHROPIC_API_KEY=
CRUSOE_API_KEY=
CRUSOE_INFERENCE_URL=https://api.inference.crusoecloud.com/v1/

# --- Internal service URLs (compose service names, not localhost) ---
# These are overridden in docker-compose.prod.yml, so just leave defaults.

# --- CORS allowlist for the orchestrator ---
# Comma-separated list of Vercel origins that can call the orch.
CORS_ORIGINS=https://argus.example.com,https://ridgeline.example.com

# --- Neo4j ---
# Generate a fresh password, do NOT reuse devpass.
NEO4J_PASSWORD=changeme
NEO4J_USER=neo4j

# --- Graphiti ---
GRAPHITI_LLM_PROVIDER=crusoe
CRUSOE_MODEL=nvidia/Nemotron-3-Nano-Omni-Reasoning-30B-A3B
SEMAPHORE_LIMIT=2
EXTRACTION_RPM_LIMIT=120
GRAPHITI_EMBEDDER_MODEL=sentence-transformers/all-MiniLM-L6-v2
GRAPHITI_GROUP_ID=argus_incidents
