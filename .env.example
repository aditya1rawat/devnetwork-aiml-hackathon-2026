TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_GATEWAY_URL=https://gateway.truefoundry.ai
CLAUDE_MODEL=anthropic/claude-sonnet-4-6
NEMOTRON_MODEL=nvidia/NVIDIA-Nemotron-3-Nano-30B-A3B

ANTHROPIC_API_KEY=
CRUSOE_API_KEY=
CRUSOE_INFERENCE_URL=https://api.inference.crusoecloud.com/v1/

MOCK_CLUSTER_URL=http://localhost:7100
ORCHESTRATOR_URL=http://localhost:7200
NEXT_PUBLIC_ORCH_URL=http://localhost:7200

# --- Incident Knowledge Base ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=devpass

# Extraction + rerank provider: nim (NVIDIA, default) | crusoe (Nemotron).
# Both OpenAI-compatible with big context + generous rate limits.
GRAPHITI_LLM_PROVIDER=nim
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_RERANK_MODEL=meta/llama-3.1-8b-instruct
GRAPHITI_EMBEDDER_MODEL=sentence-transformers/all-MiniLM-L6-v2
GRAPHITI_GROUP_ID=argus_incidents

INCIDENT_KB_MCP_URL=http://localhost:7300/mcp
INCIDENT_KB_ADMIN_URL=http://localhost:7301