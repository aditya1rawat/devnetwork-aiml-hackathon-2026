TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_GATEWAY_URL=https://gateway.truefoundry.ai
CLAUDE_MODEL=anthropic/claude-sonnet-4-6
TRIAGE_MODEL=anthropic/claude-haiku-4-5
NEMOTRON_MODEL=nvidia/Nemotron-3-Nano-Omni-Reasoning-30B-A3B

ANTHROPIC_API_KEY=
CRUSOE_API_KEY=
CRUSOE_INFERENCE_URL=https://api.inference.crusoecloud.com/v1/

MOCK_CLUSTER_URL=http://localhost:7100
ORCHESTRATOR_URL=http://localhost:7200
NEXT_PUBLIC_ORCH_URL=http://localhost:7200

# CORS allowlist for the orchestrator. `*` is fine for local dev; in prod
# set to a comma-separated list of Vercel origins, e.g.
# CORS_ORIGINS=https://argus.example.com,https://ridgeline.example.com
CORS_ORIGINS=*

# --- Incident Knowledge Base ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=devpass

# Extraction + rerank provider: crusoe (Nemotron, default) | tfy (Sonnet, backup).
# Crusoe is primary — generous limits and same model family as the shadow
# cognition. TFY backup reuses TRUEFOUNDRY_API_KEY / CLAUDE_MODEL above.
GRAPHITI_LLM_PROVIDER=crusoe
CRUSOE_MODEL=nvidia/Nemotron-3-Nano-Omni-Reasoning-30B-A3B
SEMAPHORE_LIMIT=1
EXTRACTION_RPM_LIMIT=20
GRAPHITI_EMBEDDER_MODEL=sentence-transformers/all-MiniLM-L6-v2
GRAPHITI_GROUP_ID=argus_incidents

INCIDENT_KB_MCP_URL=http://localhost:7300/mcp
INCIDENT_KB_ADMIN_URL=http://localhost:7301